@article{The_Architectur_of_language,
	title = {The architecture of language: {Understanding} the mechanics behind {LLMs}},
	volume = {1},
	copyright = {http://creativecommons.org/licenses/by/4.0},
	issn = {3033-3733},
	shorttitle = {The architecture of language},
	url = {https://www.cambridge.org/core/product/identifier/S3033373324000164/type/journal_article},
	doi = {10.1017/cfl.2024.16},
	abstract = {Large language models (LLMs) have significantly advanced artificial intelligence (AI) and natural language processing (NLP) by excelling in tasks like text generation, machine translation, question answering and sentiment analysis, often rivaling human performance. This paper reviews LLMs’ foundations, advancements and applications, beginning with the transformative transformer architecture, which improved on earlier models like recurrent neural networks and convolutional neural networks through self-attention mechanisms that capture long-range dependencies and contextual relationships. Key innovations such as masked language modeling and causal language modeling underpin leading models like Bidirectional encoder representations from transformers (BERT) and the Generative Pre-trained Transformer (GPT) series. The paper highlights scaling laws, model size increases and advanced training techniques that have driven LLMs’ growth. It also explores methodologies to enhance their precision and adaptability, including parameter-efficient fine-tuning and prompt engineering. Challenges like high computational demands, biases and hallucinations are addressed, with solutions such as retrieval-augmented generation to improve factual accuracy. By discussing LLMs’ strengths, limitations and transformative potential, this paper provides researchers, practitioners and students with a comprehensive understanding. It underscores the importance of ongoing research to improve efficiency, manage ethical concerns and shape the future of AI and language technologies.},
	language = {en},
	urldate = {2026-05-30},
	journal = {Cambridge Forum on AI: Law and Governance},
	author = {Ferraris, Andrea Filippo and Audrito, Davide and Caro, Luigi Di and Poncibò, Cristina},
	year = {2025},
	pages = {e11},
	file = {PDF:C\:\\Users\\Fabio\\Zotero\\storage\\QR5JJSHX\\Ferraris et al. - 2025 - The architecture of language Understanding the mechanics behind LLMs.pdf:application/pdf},
	keywords = {mono},
}


@article{A_Survey_of_llms_techniques_apps_and_challenges,
	title = {A survey of large language models: techniques, applications, and challenges},
	volume = {32},
	issn = {1432-1882},
	url = {https://doi.org/10.1007/s00530-026-02288-9},
	doi = {10.1007/s00530-026-02288-9},
	abstract = {Amid the rapid advancement of artificial intelligence (AI) technology, large language models (LLMs) have emerged as a pivotal force driving innovation in the field, attracting researchers due to their distinct advantages and broad application potential. Unlike existing surveys that focus on technical enumeration or single-dimensional evaluation, this work develops an integrated analytical framework of “three-dimensional trade-off + scenario adaptation”. Centered on the dynamic balance of “performance-efficiency-cost”, this framework links model architectural selection, training strategy optimization, and deployment implementation, forming a closed-loop analytical logic that bridges technical characteristics and scenario requirements. This survey presents a systematic and comprehensive overview of LLMs, articulating their evolution through a lens of performance-efficiency-cost trade-offs. Unlike prior surveys, we place a particular emphasis on the comparative analysis of architectural paradigms (Encoder-Only, Decoder-Only, Encoder–Decoder) and training strategies (e.g., RLHF vs. SFT), providing a practical framework for selecting appropriate technologies for specific application needs. We further synthesize the landscape by delving into emerging paradigms such as Retrieval-Augmented Generation (RAG) and AI Agents, and critically examine pressing challenges including hallucination, scalability, and ethical dilemmas. By integrating foundational technical reviews with forward-looking trend and governance analysis, this work establishes a decision-oriented reference framework—guiding researchers in prioritizing research directions and assisting practitioners in matching technical solutions to specific scenarios—filling the gap of ’overemphasizing technical description while lacking practical decision support’ in prior surveys. The unique value of this work, distinguishing it from prior literature, resides in three interconnected aspects: First, it takes “performance-efficiency-cost” trade-offs as the core clue to link architectural selection, training strategies, and deployment solutions (see Tables 2, 4), developing actionable technical selection logic for scenario-specific resource constraints. Second, it integrates the synergy between emerging paradigms (RAG, AI Agent) and traditional LLMs—for example, explaining how RAG reduces Decoder-Only models hallucination rate from 15.8\% to 8.3\% (Sects. 2.5.6, 4.2) and how AI Agent extends LLMs’ tool-use capabilities via transfer learning (Sect. 3.6) [1]. As a pure LLM, BioBERT outperforms untuned multimodal LLMs in text-aided low-resolution medical image recognition (e.g., matching image-based lesion features with text-derived diagnostic keywords).},
	number = {4},
	journal = {Multimedia Systems},
	author = {Ji, Jiajie and Zhao, Xueqing and Shi, Xin},
	month = may,
	year = {2026},
	pages = {303},
	keywords = {mono},
}


@incollection{Evolution_im_Dialog,
	address = {Wiesbaden},
	title = {Evolution im {Dialog}: {Vom} {Chatbot} zur {Conversational} {AI}},
	isbn = {978-3-658-49614-2},
	url = {https://doi.org/10.1007/978-3-658-49614-2_75},
	doi = {10.1007/978-3-658-49614-2_75},
	abstract = {Die Landschaft der Chatbots hat sich fundamental gewandelt: Moderne Conversational AI, basierend auf Large Language Models (LLMs), ist heute ein strategischer Hebel für exzellente Customer Experience und operative Effizienz in Unternehmen. Dieser Beitrag erklärt praxisnah die Funktionsweise dieser neuen KI-Systeme, ihre erweiterten Einsatzmöglichkeiten von der Hyperpersonalisierung bis zur Generierung tiefer Customer Insights und den daraus resultierenden Mehrwert. Er bietet Entscheidern konkrete Ratschläge für die Entwicklung eines LLM-spezifischen Konzepts – von der Strategie über Prompt Engineering und Retrieval-Augmented Generation (RAG) bis zur Tool-Auswahl. Zentrale Herausforderungen wie Halluzinationen, Datenschutz und Bias werden ebenso beleuchtet wie Lösungsansätze für eine erfolgreiche und verantwortungsvolle Implementierung von KI-basierten virtuellen Assistenten.},
	booktitle = {Praxishandbuch {Digitales} {Management}: {Band} 2: {Digital} {Marketing} und {Sales}},
	publisher = {Springer Fachmedien Wiesbaden},
	author = {Lehmann, Julia},
	editor = {Detscher, Stefan and Hepp, Michael},
	year = {2026},
	pages = {361--391},
	keywords = {mono},
}